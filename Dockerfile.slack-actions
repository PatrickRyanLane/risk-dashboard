FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080

WORKDIR /app

COPY scripts/__init__.py scripts/__init__.py
COPY scripts/slack_salesforce_actions.py scripts/slack_salesforce_actions.py

RUN pip install --no-cache-dir \
    flask==3.0.3 \
    gunicorn==23.0.0 \
    psycopg2-binary==2.9.9 \
    simple-salesforce==1.12.9

CMD ["gunicorn", "--bind", "0.0.0.0:8080", "--workers", "2", "--threads", "8", "scripts.slack_salesforce_actions:app"]
